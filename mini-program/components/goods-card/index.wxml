<!--
  商品卡片组件
  goods-card component
-->
<view class="goods-card" bindtap="onTap">
  <view class="goods-image">
    <image src="{{goods.image || '/images/goods_default.png'}}" mode="aspectFill" lazy-load />
    <view class="goods-tag" wx:if="{{goods.tag}}">{{goods.tag}}</view>
  </view>
  <view class="goods-info">
    <view class="goods-name text-ellipsis-2">{{goods.name || goods.title}}</view>
    <view class="goods-desc text-ellipsis" wx:if="{{goods.desc}}">{{goods.desc}}</view>
    <view class="goods-bottom">
      <view class="goods-price">
        <text class="price price-large">¥{{goods.price}}</text>
        <text class="price-original" wx:if="{{goods.originalPrice && goods.originalPrice > goods.price}}">
          ¥{{goods.originalPrice}}
        </text>
      </view>
      <view class="goods-sales" wx:if="{{goods.sales}}">已售{{goods.sales}}</view>
    </view>
  </view>
</view>
