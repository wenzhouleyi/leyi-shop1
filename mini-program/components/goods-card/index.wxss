/**
 * 商品卡片组件样式
 */
.goods-card {
  background: #ffffff;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.goods-image {
  position: relative;
  width: 100%;
  padding-top: 100%;
  background: #f5f5f5;
}

.goods-image image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.goods-tag {
  position: absolute;
  top: 0;
  left: 0;
  background: linear-gradient(135deg, #ff4d4f, #ff7875);
  color: #ffffff;
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 0 0 12rpx 0;
}

.goods-info {
  padding: 16rpx;
}

.goods-name {
  font-size: 28rpx;
  color: #333333;
  line-height: 1.4;
  min-height: 78rpx;
  margin-bottom: 8rpx;
}

.goods-desc {
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 8rpx;
}

.goods-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.goods-price {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.goods-sales {
  font-size: 22rpx;
  color: #999999;
}
