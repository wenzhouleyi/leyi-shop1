/**
 * 温州乐翼小程序 - 全局样式
 * HZXK Mini Program - Global Styles
 */

/* ==================== 主题颜色变量 ==================== */
page {
  /* 主色调 */
  --primary-color: #1890ff;
  --primary-light: #40a9ff;
  --primary-dark: #096dd9;
  
  /* 价格颜色 */
  --price-color: #ff4d4f;
  --price-light: #ff7875;
  
  /* 背景颜色 */
  --bg-color: #f5f6fa;
  --bg-white: #ffffff;
  --bg-light: #fafafa;
  
  /* 文字颜色 */
  --text-primary: #333333;
  --text-secondary: #999999;
  --text-placeholder: #cccccc;
  --text-disabled: #dddddd;
  
  /* 边框颜色 */
  --border-color: #eeeeee;
  --border-light: #f5f5f5;
  
  /* 功能颜色 */
  --success-color: #52c41a;
  --warning-color: #faad14;
  --error-color: #f5222d;
  --info-color: #1890ff;
  
  /* 间距 */
  --spacing-xs: 8rpx;
  --spacing-sm: 16rpx;
  --spacing-md: 24rpx;
  --spacing-lg: 32rpx;
  --spacing-xl: 48rpx;
  
  /* 圆角 */
  --radius-sm: 8rpx;
  --radius-md: 12rpx;
  --radius-lg: 16rpx;
  --radius-xl: 24rpx;
  
  /* 阴影 */
  --shadow-sm: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
  --shadow-md: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
  --shadow-lg: 0 8rpx 24rpx rgba(0, 0, 0, 0.12);
  
  font-size: 28rpx;
  line-height: 1.6;
  color: var(--text-primary);
  background-color: var(--bg-color);
}

/* ==================== 重置样式 ==================== */
view, text, image, navigator, button, input, textarea {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

button {
  background: none;
  border: none;
  outline: none;
}

button::after {
  border: none;
}

/* ==================== 通用容器 ==================== */
.container {
  width: 100%;
  min-height: 100vh;
  background-color: var(--bg-color);
}

.page-container {
  padding: var(--spacing-md);
}

/* ==================== 通用卡片 ==================== */
.card {
  background: var(--bg-white);
  border-radius: var(--radius-md);
  padding: var(--spacing-md);
  margin-bottom: var(--spacing-sm);
  box-shadow: var(--shadow-sm);
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: var(--spacing-sm);
}

/* ==================== 通用按钮 ==================== */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 80rpx;
  border-radius: var(--radius-lg);
  font-size: 30rpx;
  font-weight: 500;
}

.btn-primary {
  background: linear-gradient(135deg, var(--primary-color), var(--primary-light));
  color: #ffffff;
}

.btn-primary:active {
  opacity: 0.9;
}

.btn-default {
  background: var(--bg-white);
  color: var(--text-primary);
  border: 1rpx solid var(--border-color);
}

.btn-danger {
  background: var(--price-color);
  color: #ffffff;
}

.btn-block {
  width: 100%;
}

/* ==================== 价格样式 ==================== */
.price {
  color: var(--price-color);
  font-weight: 600;
}

.price-large {
  font-size: 40rpx;
}

.price-small {
  font-size: 24rpx;
}

.price-original {
  color: var(--text-secondary);
  text-decoration: line-through;
  font-size: 24rpx;
}

/* ==================== 标题样式 ==================== */
.title-primary {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.title-secondary {
  font-size: 28rpx;
  color: var(--text-secondary);
}

/* ==================== 分割线 ==================== */
.divider {
  height: 1rpx;
  background: var(--border-color);
  margin: var(--spacing-md) 0;
}

.divider-vertical {
  width: 1rpx;
  height: 100%;
  background: var(--border-color);
}

/* ==================== Flex 布局 ==================== */
.flex {
  display: flex;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.flex-col {
  display: flex;
  flex-direction: column;
}

.flex-wrap {
  flex-wrap: wrap;
}

.flex-1 {
  flex: 1;
}

/* ==================== 文字省略 ==================== */
.text-ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.text-ellipsis-2 {
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* ==================== 空状态 ==================== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-state image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: var(--spacing-md);
}

.empty-state text {
  color: var(--text-secondary);
  font-size: 28rpx;
}

/* ==================== 安全区域 ==================== */
.safe-area-bottom {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

/* ==================== 加载状态 ==================== */
.loading-container {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}

/* ==================== 徽章 ==================== */
.badge {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  background: var(--price-color);
  color: #fff;
  font-size: 20rpx;
  min-width: 32rpx;
  height: 32rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 8rpx;
}

/* ==================== 标签 ==================== */
.tag {
  display: inline-block;
  padding: 4rpx 12rpx;
  font-size: 22rpx;
  border-radius: var(--radius-sm);
  background: var(--bg-light);
  color: var(--text-secondary);
}

.tag-primary {
  background: rgba(24, 144, 255, 0.1);
  color: var(--primary-color);
}

.tag-danger {
  background: rgba(255, 77, 79, 0.1);
  color: var(--price-color);
}
