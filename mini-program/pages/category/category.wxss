.search-bar {
  padding: 12rpx 24rpx;
  background: #fff;
}
.search-input {
  display: flex;
  align-items: center;
  background: #f5f6fa;
  border-radius: 32rpx;
  padding: 16rpx 24rpx;
}
.search-input .icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}
.search-input .placeholder {
  color: #999;
  font-size: 28rpx;
}

.category-layout {
  display: flex;
  height: calc(100vh - 100rpx);
}
.category-sidebar {
  width: 200rpx;
  background: #f5f6fa;
}
.sidebar-item {
  padding: 32rpx 16rpx;
  font-size: 26rpx;
  color: #666;
  text-align: center;
  border-left: 4rpx solid transparent;
}
.sidebar-item.active {
  background: #fff;
  color: #1890ff;
  border-left-color: #1890ff;
  font-weight: 600;
}
.category-content {
  flex: 1;
  background: #fff;
  padding: 24rpx;
}
.subcategory-list {
  display: flex;
  flex-wrap: wrap;
  margin-bottom: 24rpx;
}
.subcategory-item {
  width: 33.33%;
  text-align: center;
  padding: 20rpx 0;
}
.sub-icon {
  width: 80rpx;
  height: 80rpx;
  background: #f5f6fa;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 12rpx;
  font-size: 36rpx;
}
.subcategory-item text {
  font-size: 24rpx;
  color: #333;
}

.product-list {
  display: flex;
  flex-wrap: wrap;
}
.product-item {
  width: 50%;
  padding: 12rpx;
}
.product-img {
  height: 200rpx;
  background: #f5f6fa;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
}
.product-info {
  padding: 12rpx 0;
}
.product-name {
  font-size: 24rpx;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.product-price {
  font-size: 28rpx;
  color: #ff4d4f;
  font-weight: 600;
  margin-top: 8rpx;
}
