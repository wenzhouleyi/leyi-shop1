.container {
  padding-bottom: 120rpx;
}
.swiper {
  height: 600rpx;
  background: #f5f6fa;
}
.slide-img {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 200rpx;
}

.info-section {
  background: #fff;
  padding: 24rpx;
}
.price-row {
  display: flex;
  align-items: baseline;
  margin-bottom: 16rpx;
}
.price {
  font-size: 48rpx;
  font-weight: 700;
  color: #ff4d4f;
}
.original {
  font-size: 28rpx;
  color: #999;
  text-decoration: line-through;
  margin-left: 16rpx;
}
.name {
  font-size: 32rpx;
  font-weight: 600;
  line-height: 1.4;
  margin-bottom: 16rpx;
}
.desc {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

.spec-section, .qty-section {
  background: #fff;
  margin-top: 16rpx;
  padding: 24rpx;
}
.spec-title {
  font-size: 28rpx;
  margin-bottom: 16rpx;
}
.spec-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}
.spec-item {
  padding: 16rpx 32rpx;
  border: 2rpx solid #e8e8e8;
  border-radius: 8rpx;
  font-size: 26rpx;
}
.spec-item.active {
  border-color: #1890ff;
  color: #1890ff;
  background: #e6f7ff;
}

.qty-section {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.qty-control {
  display: flex;
  align-items: center;
  border: 1rpx solid #e8e8e8;
  border-radius: 8rpx;
}
.qty-control text {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
}
.qty-control input {
  width: 80rpx;
  height: 56rpx;
  text-align: center;
  font-size: 28rpx;
  border-left: 1rpx solid #e8e8e8;
  border-right: 1rpx solid #e8e8e8;
}

.detail-tab {
  background: #fff;
  margin-top: 16rpx;
}
.tab-nav {
  display: flex;
  border-bottom: 1rpx solid #e8e8e8;
}
.tab-nav text {
  padding: 24rpx 32rpx;
  font-size: 28rpx;
  color: #666;
}
.tab-nav text.active {
  color: #1890ff;
  border-bottom: 4rpx solid #1890ff;
}
.tab-content {
  padding: 32rpx;
  font-size: 28rpx;
  line-height: 1.8;
  color: #666;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background: #fff;
  display: flex;
  align-items: center;
  box-shadow: 0 -2rpx 12rpx rgba(0,0,0,0.05);
}
.icon-btn {
  flex: 1;
  text-align: center;
}
.icon-btn text {
  display: block;
  font-size: 22rpx;
}
.icon-btn text:first-child {
  font-size: 36rpx;
  margin-bottom: 4rpx;
}
.btn-cart, .btn-buy {
  width: 200rpx;
  height: 72rpx;
  line-height: 72rpx;
  font-size: 28rpx;
  color: #fff;
  border-radius: 0;
  margin: 0;
}
.btn-cart {
  background: #faad14;
}
.btn-buy {
  background: #ff4d4f;
}
