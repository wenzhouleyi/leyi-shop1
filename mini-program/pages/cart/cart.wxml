<view class="container">
  <view class="cart-header">
    <text class="title">购物车</text>
    <text class="edit" bindtap="toggleEdit">{{isEdit ? '完成' : '管理'}}</text>
  </view>
  
  <view class="empty-state" wx:if="{{cart.length === 0}}">
    <text class="empty-icon">🛒</text>
    <text class="empty-text">购物车是空的</text>
    <button class="btn-go" bindtap="goHome">去逛逛</button>
  </view>
  
  <view class="cart-list" wx:else>
    <view class="cart-item" wx:for="{{cart}}" wx:key="id">
      <checkbox checked="{{item.selected}}" bindtap="toggleSelect" data-id="{{item.id}}"/>
      <view class="item-img">📱</view>
      <view class="item-info">
        <text class="item-name">{{item.name}}</text>
        <text class="item-price">¥{{item.price}}</text>
      </view>
      <view class="item-qty">
        <text bindtap="changeQty" data-id="{{item.id}}" data-delta="-1">-</text>
        <input type="number" value="{{item.quantity}}" disabled/>
        <text bindtap="changeQty" data-id="{{item.id}}" data-delta="1">+</text>
      </view>
    </view>
  </view>
  
  <view class="cart-footer" wx:if="{{cart.length > 0}}">
    <view class="select-all" bindtap="toggleSelectAll">
      <checkbox checked="{{selectAll}}"/>
      <text>全选</text>
    </view>
    <view class="total">
      <text>合计：</text>
      <text class="amount">¥{{totalAmount}}</text>
    </view>
    <button class="btn-checkout" bindtap="checkout">结算({{selectedCount}})</button>
  </view>
</view>
