.container {
  padding-bottom: 120rpx;
}
.cart-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  background: #fff;
}
.cart-header .title {
  font-size: 36rpx;
  font-weight: 600;
}
.cart-header .edit {
  color: #1890ff;
  font-size: 28rpx;
}

.empty-state {
  text-align: center;
  padding: 120rpx 0;
}
.empty-icon {
  font-size: 120rpx;
  display: block;
  margin-bottom: 24rpx;
}
.empty-text {
  color: #999;
  font-size: 28rpx;
  display: block;
  margin-bottom: 32rpx;
}
.btn-go {
  width: 240rpx;
  height: 72rpx;
  background: #1890ff;
  color: #fff;
  border-radius: 36rpx;
  font-size: 28rpx;
}

.cart-list {
  padding: 16rpx;
}
.cart-item {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}
.item-img {
  width: 160rpx;
  height: 160rpx;
  background: #f5f6fa;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
  margin: 0 16rpx;
}
.item-info {
  flex: 1;
}
.item-name {
  font-size: 28rpx;
  color: #333;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.item-price {
  color: #ff4d4f;
  font-size: 32rpx;
  font-weight: 600;
  margin-top: 16rpx;
}
.item-qty {
  display: flex;
  align-items: center;
  border: 1rpx solid #e8e8e8;
  border-radius: 8rpx;
}
.item-qty text {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #666;
}
.item-qty input {
  width: 60rpx;
  height: 48rpx;
  text-align: center;
  font-size: 26rpx;
  border-left: 1rpx solid #e8e8e8;
  border-right: 1rpx solid #e8e8e8;
}

.cart-footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background: #fff;
  display: flex;
  align-items: center;
  padding: 0 24rpx;
  box-shadow: 0 -2rpx 12rpx rgba(0,0,0,0.05);
}
.select-all {
  display: flex;
  align-items: center;
  font-size: 26rpx;
}
.select-all checkbox {
  margin-right: 8rpx;
}
.total {
  flex: 1;
  text-align: right;
  margin-right: 24rpx;
  font-size: 26rpx;
}
.total .amount {
  color: #ff4d4f;
  font-size: 36rpx;
  font-weight: 700;
}
.btn-checkout {
  width: 200rpx;
  height: 72rpx;
  background: #ff4d4f;
  color: #fff;
  border-radius: 36rpx;
  font-size: 28rpx;
}
