# ============================================
# 温州乐翼电商系统 - 环境变量配置
# 复制此文件为 .env 并填写实际值
# ============================================

# 服务器端口 (Railway/Render会自动设置)
PORT=3000

# 环境模式
NODE_ENV=production

# JWT密钥 (请修改为随机字符串)
JWT_SECRET=your-super-secret-key-change-this-in-production

# 管理后台账号密码 (首次部署后请修改)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# 文件上传配置
MAX_FILE_SIZE=10485760
UPLOAD_DIR=./uploads

# CORS配置 (如需跨域访问)
ALLOWED_ORIGINS=http://localhost:3000,https://www.leyi.com

# 数据库备份路径
BACKUP_DIR=./backups
